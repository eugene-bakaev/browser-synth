{
  "name": "browser-synth",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:client": "npm run dev -w @fiddle/client",
    "dev:server": "npm run dev -w @fiddle/server",
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:obs:server": "npm run dev:obs -w @fiddle/server",
    "dev:obs": "npm-run-all --parallel dev:client dev:obs:server",
    "build:client": "npm run build -w @fiddle/client",
    "build:server": "npm run build -w @fiddle/server",
    "build": "npm run build:client && npm run build:server",
    "test:client": "npm run test -w @fiddle/client",
    "test:server": "npm run test -w @fiddle/server",
    "test": "npm test --workspaces --if-present",
    "typecheck:client": "npm run typecheck -w @fiddle/client",
    "typecheck:server": "npm run typecheck -w @fiddle/server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:e2e:server": "npm run test:e2e -w @fiddle/server",
    "e2e": "playwright test",
    "lab": "npm run lab -w @fiddle/audio-lab --",
    "lab:audit": "npm run audit -w @fiddle/audio-lab",
    "lab:audit:fast": "npm run audit:fast -w @fiddle/audio-lab"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "npm-run-all": "^4.1.5"
  }
}
