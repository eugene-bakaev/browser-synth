{
  "name": "@fiddle/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --alias:@fiddle/shared=../shared/src/index.ts --outfile=dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "@fiddle/shared": "*",
    "fastify": "^5.0.0",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.21.5",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
