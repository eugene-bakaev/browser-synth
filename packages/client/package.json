    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "^4.1.7",
    "esbuild": "^0.21.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.0.0"
  }
}
